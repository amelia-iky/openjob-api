{
  "name": "openjob-api",
  "version": "1.0.0",
  "main": "src/app.js",
  "type": "module",
  "scripts": {
    "start": "node src/app.js",
    "dev": "nodemon src/app.js",
    "migrate:up": "node-pg-migrate -m src/migrations up",
    "migrate:down": "node-pg-migrate -m src/migrations down",
    "migrate:create": "node-pg-migrate -m src/migrations create",
    "migrate:fresh": "node -r dotenv/config ./node_modules/.bin/node-pg-migrate -m src/migrations down -a && node -r dotenv/config ./node_modules/.bin/node-pg-migrate -m src/migrations up"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "joi": "^18.2.1",
    "jsonwebtoken": "^9.0.3",
    "multer": "^2.1.1",
    "nanoid": "^5.1.11",
    "pg": "^8.20.0"
  },
  "devDependencies": {
    "node-pg-migrate": "^8.0.4",
    "nodemon": "^3.1.14"
  }
}
